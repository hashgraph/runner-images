{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pre-commit run:*)",
      "Bash(pre-commit install:*)",
      "Bash(hadolint:*)",
      "Bash(yamllint:*)",
      "Bash(shellcheck:*)",
      "Bash(docker buildx ls)",
      "Bash(docker buildx build:*)",
      "Bash(docker images:*)",
      "Bash(docker image inspect:*)",
      "Bash(docker history:*)",
      "Bash(docker version)",
      "Bash(docker info)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(semver:*)",
      "Bash(yq:*)",
      "Bash(jq:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse:*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:edu.chainguard.dev)",
      "WebFetch(domain:images.chainguard.dev)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:pre-commit.com)",
      "WebFetch(domain:www.stepsecurity.io)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git commit --amend:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(docker push:*)",
      "Bash(docker login:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh workflow enable:*)",
      "Bash(gh workflow disable:*)"
    ]
  }
}
